GROQ_API_KEY=your_key_here
# Optional override; defaults to llama-3.3-70b-versatile
# GROQ_MODEL=llama-3.1-8b-instant

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Public base URL — used in OAuth redirects and share URLs.
# In production set this to your deployed URL (e.g. https://pastecv.dev).
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Admin dashboard — no env var needed.
# On the first visit to /admin/login, you'll set the username "admin"
# password via the UI. The hash is stored in the admin_config table.

# Transactional email (optional — for /admin/users mail composer).
# Uses SMTP. Easiest setup: Gmail + App Password (no domain needed, 500/day).
#   1. Enable 2-step verification on your Google account
#   2. Visit https://myaccount.google.com/apppasswords
#   3. Create app password labelled "PasteCV" → copy 16-char string
# Without these, the composer still works but only generates previews.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=you@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
# Must match SMTP_USER for Gmail. Format: "PasteCV <you@gmail.com>"
MAIL_FROM=PasteCV <you@gmail.com>
# Optional. URL embedded inside outbound emails (defaults to the prod URL,
# NOT NEXT_PUBLIC_BASE_URL — so mail sent from local dev still links to prod).
MAIL_SITE_URL=https://paste-cv.vercel.app

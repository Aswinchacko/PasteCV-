GROQ_API_KEY=your_key_here
# Optional override; defaults to llama-3.3-70b-versatile
# GROQ_MODEL=llama-3.1-8b-instant

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Public base URL — used in OAuth redirects and share URLs.
# In production set this to your deployed URL (e.g. https://pastecv.dev).
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Admin dashboard — no env var needed.
# On the first visit to /admin/login, you'll set the username "admin"
# password via the UI. The hash is stored in the admin_config table.
